generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Job {
  id              String    @id @default(cuid())
  company         String
  role            String
  status          String    @default("saved")
  priority        String    @default("medium")
  excitement      Int?
  pinned          Boolean   @default(false)
  archived        Boolean   @default(false)
  color           String?
  tags            String?

  jobUrl          String?
  jobDescription  String?
  parsedKeywords  String?
  parsedTechStack String?

  location        String?
  remote          Boolean   @default(false)
  hybrid          Boolean   @default(false)

  salary          String?
  salaryRaw       String?
  salaryMin       Int?
  salaryMax       Int?
  currency        String?   @default("CAD")

  companySize     String?
  companyStage    String?
  industry        String?
  benefits        String?
  visaSponsorship Boolean   @default(false)

  source          String?
  referralContact String?
  resumeVersion   String?
  dateApplied     DateTime  @default(now())
  deadline        DateTime?
  followUpDate    DateTime?
  lastContactDate DateTime?
  recruiterName   String?
  recruiterEmail  String?
  recruiterPhone  String?

  offerDeadline   DateTime?
  offerAmount     String?
  rejectionReason String?

  notes           String?

  aiScore         Int?
  aiSuggestion    String?
  aiStrengths     String?
  aiRisks         String?
  aiNextSteps     String?
  aiKeySkills     String?
  aiSalaryInsight String?
  aiCultureFit    String?
  aiLastAnalyzed  DateTime?

  discoveredBy    String?
  agentSessionId  String?
  agentNotes      String?

  coverLetter     String?
  techStack       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  interviews         Interview[]
  activities         Activity[]
  documents          Document[]
  contacts           Contact[]
  tasks              Task[]
  salaryNegotiations SalaryNegotiation[]
  applicationQAs     ApplicationQA[]
}

model Interview {
  id               String   @id @default(cuid())
  jobId            String
  round            Int      @default(1)
  type             String
  scheduledAt      DateTime
  duration         Int?
  interviewers     String?
  platform         String?
  location         String?
  notes            String?
  prepNotes        String?
  questionsAsked   String?
  myQuestions      String?
  outcome          String   @default("scheduled")
  feedbackReceived String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  jobId     String
  type      String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  type      String
  content   String
  version   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Contact {
  id           String    @id @default(cuid())
  jobId        String
  name         String
  title        String?
  email        String?
  phone        String?
  linkedin     String?
  relationship String    @default("other")
  notes        String?
  lastContact  DateTime?
  createdAt    DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  jobId       String
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SalaryNegotiation {
  id         String   @id @default(cuid())
  jobId      String
  round      Int      @default(1)
  theirOffer String?
  myCounter  String?
  notes      String?
  outcome    String?
  date       DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ApplicationQA {
  id        String   @id @default(cuid())
  jobId     String
  question  String
  answer    String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id              String   @id @default(cuid())
  name            String   @default("")
  email           String   @default("")
  phone           String   @default("")
  linkedin        String   @default("")
  github          String   @default("")
  portfolio       String   @default("")
  currentTitle    String   @default("")
  yearsExperience Int      @default(0)
  targetRoles     String   @default("")
  targetSalaryMin Int      @default(0)
  targetSalaryMax Int      @default(0)
  currency        String   @default("CAD")
  skills          String   @default("")
  education       String   @default("")
  bio             String   @default("")
  masterResume    String   @default("")
  jobSearchGoals  String   @default("")
  preferRemote    Boolean  @default(false)
  preferHybrid    Boolean  @default(true)
  targetLocations String   @default("")
  excludeKeywords String   @default("")
  weeklyGoal      Int      @default(5)
  defaultSource   String   @default("LinkedIn")
  timezone        String   @default("America/Toronto")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentSession {
  id            String    @id @default(cuid())
  status        String    @default("running")
  searchQueries String?
  jobsFound     Int       @default(0)
  jobsAdded     Int       @default(0)
  jobsFiltered  Int       @default(0)
  log           String?
  error         String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String
  type      String
  isDefault Boolean  @default(false)
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
