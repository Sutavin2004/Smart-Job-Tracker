# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite (data lives in prisma/dev.db — run `npm run db:migrate`)
DATABASE_URL="file:./dev.db"

# Production (Vercel): use Neon free tier → https://neon.tech
# 1. Create a project on neon.tech
# 2. Copy the connection string (postgresql://...)
# 3. Change prisma/schema.prisma datasource provider to "postgresql"
# 4. Run: npx prisma migrate deploy
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Powers: job discovery agent, cover letters, resume analysis, interview prep
# Get your key → https://console.anthropic.com/settings/keys
# Without this key the app still works — AI endpoints return a 503 gracefully.
ANTHROPIC_API_KEY="sk-ant-..."

# ── Job Board APIs (optional — add for real live job listings) ─────────────────

# JSearch via RapidAPI — scrapes LinkedIn, Indeed & Glassdoor (500 free req/month)
# Sign up: https://rapidapi.com → search "JSearch" → Subscribe to free plan
RAPIDAPI_KEY=""

# Adzuna — free public job board API (10,000 req/month on free plan)
# Sign up: https://developer.adzuna.com → Register → Create App
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# RemoteOK is always active — no key needed (remote jobs only)
