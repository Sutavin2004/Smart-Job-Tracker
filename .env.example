# ── Database (PostgreSQL required — SQLite is no longer supported) ────────────
#
# The app uses PostgreSQL in all environments (local dev + Vercel production).
# Get a FREE PostgreSQL database in 60 seconds:
#
#   Option A — Neon (recommended): https://neon.tech
#     1. Sign up → create project → copy the connection string
#     2. Neon gives you TWO URLs: a pooled URL and a direct URL.
#        Set DATABASE_URL  = pooled connection string  (postgres://...@-pooler....)
#        Set DIRECT_URL    = direct connection string  (postgres://...@ep-...)
#
#   Option B — Supabase: https://supabase.com → new project → Settings → Database
#     Set DATABASE_URL and DIRECT_URL to the same connection string
#
# After setting DATABASE_URL, run once to create all tables:
#   npx prisma migrate deploy
#
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Powers: job discovery agent, cover letters, resume analysis, interview prep
# Get your key → https://console.anthropic.com/settings/keys
# Without this key the app still works — AI endpoints return a 503 gracefully.
ANTHROPIC_API_KEY="sk-ant-..."

# ── Job Board APIs (optional — add for real live job listings) ─────────────────

# JSearch via RapidAPI — scrapes LinkedIn, Indeed & Glassdoor (500 free req/month)
# Sign up: https://rapidapi.com → search "JSearch" → Subscribe to free plan
RAPIDAPI_KEY=""

# Adzuna — free public job board API (10,000 req/month on free plan)
# Sign up: https://developer.adzuna.com → Register → Create App
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# RemoteOK is always active — no key needed (remote jobs only)
